# =============================================================================
# aragonteam Service Configuration
# Read by install.sh — re-run install.sh after modifying this file.
# Generated by web-deployer skill — 2026-07-20
# =============================================================================

# ---------------------------------------------------------------------------
# Project identity
# ---------------------------------------------------------------------------
PROJECT_NAME="aragonteam"
PROJECT_DIR="/opt/aragonteam"

# ---------------------------------------------------------------------------
# Runtime users
# ---------------------------------------------------------------------------
RUN_USER="aragonteam"
RUN_GROUP="aragonteam"
USER_DATA_DIR="/var/lib/aragonteam"

# ---------------------------------------------------------------------------
# Runtime binaries (auto-detected if empty; set these if auto-detection fails)
# ---------------------------------------------------------------------------
# NODE_BIN=/usr/bin/node
# VENV_PYTHON=/opt/aragonteam/backend/.venv/bin/python

# ---------------------------------------------------------------------------
# Ports
# ---------------------------------------------------------------------------
BACKEND_PORT=5000
FRONTEND_PORT=3000

# ---------------------------------------------------------------------------
# Health check URLs (used by healthcheck.sh and install.sh readiness probes)
# ---------------------------------------------------------------------------
BACKEND_HEALTH_URL="http://127.0.0.1:${BACKEND_PORT:-5000}/api/health"
BACKEND_HEALTH_FALLBACK_URL="http://127.0.0.1:${BACKEND_PORT:-5000}/api/health"
FRONTEND_HEALTH_URL="http://127.0.0.1:${FRONTEND_PORT:-3000}/"

# ---------------------------------------------------------------------------
# Watchdog
# ---------------------------------------------------------------------------
WATCHDOG_INTERVAL=60        # Health check interval (seconds)
WATCHDOG_FAIL_THRESHOLD=5   # Consecutive failures before restart
WATCHDOG_STATE_DIR=/tmp     # Directory for failure counter files

# ---------------------------------------------------------------------------
# Nginx reverse proxy (leave NGINX_DOMAIN empty to skip auto-configuration)
# ---------------------------------------------------------------------------
NGINX_DOMAIN="120.26.57.40"
NGINX_SITE_NAME="aragonteam"

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_DIR=logs                # Relative to project root
LOG_MAX_SIZE=50M            # Max size per log file before rotation
LOG_ROTATE_COUNT=7          # Number of rotated files to keep

# ---------------------------------------------------------------------------
# Deployment mode: "systemd" or "docker"
# ---------------------------------------------------------------------------
DEPLOY_MODE="systemd"

# ---------------------------------------------------------------------------
# Project structure: "separated" (backend/ + frontend/) or "monolith"
# ---------------------------------------------------------------------------
PROJECT_STRUCTURE="separated"

# ---------------------------------------------------------------------------
# Framework identifiers (used by deploy.sh for build/start commands)
# ---------------------------------------------------------------------------
BACKEND_FRAMEWORK="flask"
BACKEND_SUBDIRECTORY="backend"
BACKEND_START_COMMAND="/opt/aragonteam/backend/.venv/bin/gunicorn --workers 1 --threads 4 --bind 127.0.0.1:5000 --access-logfile - --error-logfile - app:app"
FRONTEND_FRAMEWORK="nextjs"
FRONTEND_SUBDIRECTORY="frontend"
FRONTEND_START_COMMAND="/usr/bin/npm run start -- --hostname 127.0.0.1 --port 3000"
FRONTEND_BUILD_COMMAND="npm run build"

# ---------------------------------------------------------------------------
# Package manager: "npm", "yarn", "pnpm", "pip", "pipenv", "poetry", "conda"
# ---------------------------------------------------------------------------
NODE_PACKAGE_MANAGER="npm"
PYTHON_PACKAGE_MANAGER="pip"
